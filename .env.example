# ── Printo environment configuration ──────────────────────────────────────────
# Copy to `.env` and fill in. All values are optional; sensible defaults apply
# and the app runs fully in mock mode with none of them set.

# ── AI extraction provider ────────────────────────────────────────────────────
# Printo does NOT call a foundation-model API directly. All inference is routed
# through a pluggable AI sidecar (the Pratyaya / Ampris AI-aaS pattern).
#
#   AI_PROVIDER = auto | gateway | sidecar | mock
#     auto    → prefer the Printo Gateway, else a local sidecar, else mock
#     gateway → always use the Printo Gateway (Hostinger VPS) via printo_gateway_client
#     sidecar → always use the local HTTP sidecar
#     mock    → always use built-in demo data (no network)
AI_PROVIDER=auto

# ── Printo Gateway (Hostinger VPS sidecar) ─────────────────────────────────────
# Real AI-aaS. Requires the `printo_gateway_client` package (pip install — provided
# by Coral). The client reads these two env vars; extraction + ERP_MAP run server-side.
PRINTO_GATEWAY_URL=http://127.0.0.1:8095
PRINTO_GATEWAY_KEY=

# Local HTTP sidecar (fallback / dev — see tools/mock_sidecar.py for the contract).
SIDECAR_URL=http://localhost:8787
SIDECAR_API_KEY=
# vision | text | auto  (auto picks vision if /health advertises "vision": true)
SIDECAR_MODE=auto
# Request timeout (seconds) for a single sidecar call.
SIDECAR_TIMEOUT=45

# ── Extraction tuning ─────────────────────────────────────────────────────────
# Two-pass extraction: a dedicated title-block crop pass + a full-plan pass.
# More accurate, but adds one extra sidecar call per drawing.
MULTIPASS=false
# OCR fallback (requires the Tesseract binary on PATH). Degrades gracefully if absent.
OCR_ENABLED=true
# DPI used when rendering PDF pages to images before extraction.
RENDER_DPI=220

# ── RealSoft ERP (optional — simulation mode used when blank) ──────────────────
REALSOFT_BASE_URL=
REALSOFT_API_KEY=
REALSOFT_TIMEOUT=30

# ── ERP value mapping ──────────────────────────────────────────────────────────
# Target ERP module and how extracted values are mapped/flagged.
REALSOFT_MODULE=DrawingMaster
# Mapped fields whose source confidence is below this are flagged for ERP review.
MAP_LOW_CONF_THRESHOLD=0.6
# How to represent missing values in the payload: "null" (JSON null) or "empty" ("").
MAP_NULL_MODE=null

# ── Authentication ─────────────────────────────────────────────────────────────
# JWT signing secret — CHANGE THIS in production (rotate periodically).
AUTH_SECRET=change-me-in-production
TOKEN_EXPIRY_HOURS=8
REMEMBER_EXPIRY_DAYS=30
# Seeded admin account (created on first run if the users table is empty).
ADMIN_USERNAME=Admin
ADMIN_EMAIL=admin@printo.local
ADMIN_PASSWORD=Admin@123
# Brute-force protection
MAX_ATTEMPTS=5
LOCKOUT_SECONDS=300

# ── Optional: direct Anthropic fallback (disabled by default) ──────────────────
# Only used if AI_PROVIDER is set to a direct-API mode in a future build.
# ANTHROPIC_API_KEY=

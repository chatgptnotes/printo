# Supabase (ERP Realsoft project)
# Use credentials from the new, separate ERP Realsoft Supabase instance.
NEXT_PUBLIC_SUPABASE_URL=https://your-realsoft-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_realsoft_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_realsoft_supabase_service_role_key

# Auth
JWT_SECRET=replace_with_a_long_random_realsoft_secret

# Gmail Account to Monitor
GMAIL_ACCOUNT=estimation@realsoft.example
# Optional: used to list/download public Google Drive folder links found in RFQ emails.
GOOGLE_DRIVE_API_KEY=your_public_drive_api_key

# Anthropic Claude — drives every AI call (classification, extraction, electrical analysis)
# Required for Auto-Run-to-BOQ — /estimate uses claude-sonnet-4-6 by default.
# Get a key at console.anthropic.com. Token usage is logged to sabi_activity_log
# per project; disruption (401/429/529/5xx) fires a WhatsApp alert via OpenClaw.
# Used only on the legacy SDK path (USE_AI_GATEWAY != 'true'). After the
# gateway cutover bakes for a week in prod, this var is removed.
ANTHROPIC_API_KEY=your_anthropic_api_key

# Nexaproc AI Gateway — replaces direct Anthropic SDK calls when
# USE_AI_GATEWAY=true. Sidecar pool (3 replicas, least_conn) on the VPS
# shared with sister tenants. Per-tenant key auth via X-Nexaproc-Key.
# When USE_AI_GATEWAY=true, ANTHROPIC_API_KEY is no longer required at
# runtime — the gateway provisions Claude on its side.
NEXAPROC_GATEWAY_URL=https://ai-gateway.nexaproc.example
# Compatibility env key. Keep the DRAWTOBOQ_* name unless the gateway tenant
# and task prefixes are migrated in the same release.
DRAWTOBOQ_AIAS_KEY=your_realsoft_gateway_sidecar_key
USE_AI_GATEWAY=false

# OpenClaw (WhatsApp notifications)
OPENCLAW_HOST=http://192.168.1.13
OPENCLAW_PORT=18789
OPENCLAW_GATEWAY_TOKEN=your_gateway_token
OPENCLAW_HOOK_TOKEN=your_hook_token

# WhatsApp Notification Recipients
WHATSAPP_NOTIFY_NUMBER=+919373111709

# Estimation Defaults
DEFAULT_MARGIN_PERCENT=15

# Cron Secret (for Vercel cron jobs)
CRON_SECRET=your_cron_secret

# Internal-service secret used by the bid-decision route to authenticate
# its own background calls into /quick-estimate and /estimate. Set in prod
# so estimation survives the originating user's JWT expiry. Optional in dev
# (falls back to forwarding the user's auth-token cookie).
INTERNAL_API_SECRET=your_internal_api_secret

# App
# Keep localhost for local development. Set the final ERP Realsoft production domain
# in Vercel/Supabase redirect settings later when it is available.
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Demo flag — when set to "1", the bid detail page hides HVAC, Plumbing, and
# generic-MEP discipline sections, surfacing only the Electrical 14-step
# Cable Schedule Derivation. Backend processing is unaffected; unset (or any
# value other than "1") to restore the multi-discipline view.
NEXT_PUBLIC_ELECTRICAL_ONLY=

# Library-first preflight for the electrical pipeline.
# `on` = libraries pre-extract scale/floors/drawings/schedules before Sonnet.
ELECTRICAL_PREFLIGHT=
# Geometry-based cable lengths (pixels × m_per_px). Replaces sub-step 10/13
# guesses with measured values when a polyline is supplied.
ELECTRICAL_GEOMETRY=
# OpenCV symbol template matching (Phase 4 — skeleton, not yet active).
SYMBOL_TEMPLATE_MATCH=

# Test-fixture replay — when set to "1", uploads matching a captured
# tests/fixtures/ entry (by SHA-256 of file bytes) skip Claude and serve the
# recorded ElectricalProcedureResult + Power BOQ PDF in <1s. Different files
# fall through to the real pipeline. Capture with scripts/capture-fixture.mjs
# after one real successful run.
# DO NOT SET in production — server logs a warning if this is enabled there.
SABI_TEST_FIXTURES=0

# DWG auto-conversion fallback. Uploaded .dwg files are first converted in-
# process for free (LibreDWG-WASM → DXF text). If that yields nothing usable,
# and this key is set, CloudConvert renders the DWG → PDF for full vision
# scanning. Leave UNSET to disable the paid fallback — DWGs that the free path
# can't read are then skipped with a "convert manually" message.
CLOUDCONVERT_API_KEY=
# Optional: cap the whole CloudConvert round-trip (ms). Default 90000.
CLOUDCONVERT_TIMEOUT_MS=

# Worker-only Supabase setting
# The standalone VPS worker reads SUPABASE_URL instead of NEXT_PUBLIC_SUPABASE_URL.
# Set it to the same ERP Realsoft Supabase project URL only in the worker environment.
SUPABASE_URL=https://your-realsoft-project-ref.supabase.co
